{
  "name": "card-counter",
  "version": "0.2.0",
  "description": "Local-first blackjack card-counting trainer & live-session assistant (Electron + React + TypeScript)",
  "private": false,
  "type": "module",
  "main": "dist-electron/main.js",
  "author": "EatonBeavers",
  "repository": {
    "type": "git",
    "url": "https://github.com/EatonBeavers/card-counter.git"
  },
  "bugs": {
    "url": "https://github.com/EatonBeavers/card-counter/issues"
  },
  "homepage": "https://github.com/EatonBeavers/card-counter#readme",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win nsis",
    "package:win-portable": "npm run build && electron-builder --win zip"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vosk-browser": "^0.0.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.0.5"
  },
  "build": {
    "appId": "com.cardcounter.app",
    "productName": "Card Counter",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "public/models/vosk-model-small-en-us.tar.gz",
        "to": "models/vosk-model-small-en-us.tar.gz"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
